{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential client lead from the agency contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the contact" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "calendarLink": { "type": "string", "description": "User's calendar or booking link" },
        "website": { "type": "string", "format": "uri", "description": "Shopify store URL" },
        "budget": { "type": "string", "description": "Estimated project budget" },
        "services": { "type": "array", "items": { "type": "string" }, "description": "Selected services from checklist" },
        "other": { "type": "string", "description": "Additional details if 'Other' is checked" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["name", "email", "website", "budget", "services", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of incoming project leads"
    }
  }
}
