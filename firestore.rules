rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Use the email from runtime context
      return isSignedIn() && request.auth.token.email == 'arafatinbusiness@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'website', 'budget', 'services', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.website is string && data.website.size() <= 500 &&
             data.budget is string && data.budget.size() <= 100 &&
             (data.get('calendarLink', '') is string && data.get('calendarLink', '').size() <= 500) &&
             data.services is list && data.services.size() <= 20 &&
             data.createdAt == request.time;
    }

    // Leads collection
    match /leads/{leadId} {
      // Public can create leads if they follow the schema
      allow create: if isValidLead(request.resource.data);
      
      // Only admin (Arafat) can read or manage leads
      allow read, update, delete: if isAdmin();
    }
  }
}
